{
  "name": "poinz-client",
  "version": "0.20.3",
  "description": "Distributed Planning Poker",
  "private": true,
  "author": "xeronimus@gmail.com",
  "license": "MIT",
  "homepage": "https://github.com/Zuehlke/poinz",
  "repository": {
    "type": "git",
    "url": "https://github.com/Zuehlke/poinz.git"
  },
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.[jt]s?\" \"test/**/*.[jt]s\" \"viteConfig/**/*.[jt]s\" \"./*.[jt]s\"",
    "test": "jest",
    "pretest": "npm run lint"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "date-fns": "4.4.0",
    "history": "5.3.0",
    "linkify-react": "^4.3.3",
    "loglevel": "1.9.2",
    "nanoid": "^5.1.14",
    "posthog-js": "^1.390.2",
    "purecss": "3.0.0",
    "react": "^19.2.7",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.2.7",
    "react-dropzone": "15.0.0",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.3.0",
    "redux": "5.0.1",
    "remark-gfm": "^4.0.1",
    "reselect": "5.2.0",
    "socket.io-client": "4.8.3",
    "styled-components": "6.4.2",
    "whatwg-fetch": "^3.6.20"
  },
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@babel/preset-env": "8.0.2",
    "@babel/preset-react": "8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@eslint/js": "^10.0.1",
    "@quickbaseoss/babel-plugin-styled-components-css-namespace": "^1.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-jest": "^30.4.1",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "latest"
  },
  "browserslist": [
    "defaults",
    "edge 18"
  ],
  "engines": {
    "node": ">=26"
  },
  "jest": {
    "transform": {
      "^.+\\.[jt]sx?$": [
        "babel-jest",
        {
          "configFile": "./test/.babelrc"
        }
      ]
    },
    "testMatch": [
      "**/test/unit/**/*Test.[jt]s?(x)",
      "**/test/integration/**/*Test.[jt]s?(x)"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/test/unit/setup.js"
    ],
    "transformIgnorePatterns": [
      "/node_modules/(?!nanoid).+\\.js$"
    ],
    "moduleNameMapper": {
      "^.+\\.(css|less|scss)$": "<rootDir>/test/styleMock.js"
    }
  }
}
